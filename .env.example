# ===== Asayomi 環境変数サンプル =====
# `cp .env.example .env` してから値を埋めてください。
# 空欄のままで OK な変数は機能ごとオフ（メール送らない等）になります。

# ----- 基本 -----
DEBUG=false
DATABASE_URL=sqlite:///./asayomi.db

# ----- Azure OpenAI（必須・AI 機能を使う場合）-----
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-small

# ----- 収集 -----
COLLECTION_INTERVAL_HOURS=8
DATA_RETENTION_DAYS=30

# ----- フロントエンド -----
FRONTEND_URL=http://localhost:5173

# ----- SMTP / メール通知（任意）-----
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
NOTIFY_EMAIL=

# ----- Webhook 通知（任意）-----
WEBHOOK_URL=
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# ----- RSS 出力 -----
RSS_SITE_URL=http://localhost:5173
RSS_MAX_ITEMS=50
